			{
				"name": "Trigger_Databricks_ELT",
				"type": "DatabricksNotebook",
				"dependsOn": [
					{
						"activity": "ForEach_Source",
						"dependencyConditions": [
							"Succeeded"
						]
					}
				],
				"policy": {
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"notebookPath": "/pipelines/orchestrate_elt",
					"baseParameters": {
						"run_date": {
							"value": "@formatDateTime(pipeline().TriggerTime, 'yyyy-MM-dd')",
							"type": "Expression"
						},
						"triggered_by": {
							"value": "@pipeline().RunId",
							"type": "Expression"
						}
					}
				}
			}
