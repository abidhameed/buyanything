{
	"name": "pl_master_ingestion",
	"properties": {
		"description": "Metadata-driven master ingestion pipeline",
		"activities": [
			{
				"name": "Lookup_ActiveSources",
				"type": "Lookup",
				"dependsOn": [],
				"policy": {
					"retry": 0,
					"retryIntervalInSeconds": 30,
					"secureOutput": false,
					"secureInput": false
				},
				"userProperties": [],
				"typeProperties": {
					"source": {
						"type": "AzureSqlSource",
						"sqlReaderQuery": {
							"value": "SELECT * FROM dbo.pipeline_control_config WHERE is_active = 1 AND ('@{pipeline().parameters.source_type_filter}' = 'ALL' OR source_type = '@{pipeline().parameters.source_type_filter}') ORDER BY priority ASC",
							"type": "Expression"
						},
						"partitionOption": "None"
					},
					"firstRowOnly": false
				}
			},
			{
				"name": "ForEach_Source",
				"type": "ForEach",
				"dependsOn": [
					{
						"activity": "Lookup_ActiveSources",
						"dependencyConditions": [
							"Succeeded"
						]
					}
				],
				"userProperties": [],
				"typeProperties": {
					"items": {
						"value": "@activity('Lookup_ActiveSources').output.value",
						"type": "Expression"
					},
					"isSequential": false,
					"batchCount": 5,
