						"type": "AzureSqlSource",
						"sqlReaderQuery": {
							"value": "select * from  SalesOrders where orderdate > '@{activity,'last_date').output.value[0].lasdate}' and orderdate <= '@{activity('max_date').output.value[0].maxdate}'",
